# Copy to .env.local and fill values (Next.js reads .env.local in dev/production)

# MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=interact_hrm

# Built-in face verification (no external API)
FACE_VERIFICATION_ENABLED=true
FACE_MATCH_MAX_DISTANCE=0.55
FACE_MIN_MATCH_PHOTOS=2

# Encrypt passwords stored for Remember me (change in production)
SAVED_LOGIN_SECRET=your-long-random-secret-here

# Auto presence / auto clock-out sweep
AUTO_PRESENCE_SWEEP_ENABLED=true
AUTO_PRESENCE_SWEEP_INTERVAL_MS=30000
