<Window x:Class="InteractPresence.AreYouThereWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Interact Presence"
        Width="420" Height="360"
        MinHeight="360"
        ResizeMode="NoResize"
        WindowStyle="ToolWindow"
        Topmost="True"
        Background="#FFF8FAFC">
  <Border BorderBrush="#CBD5E1" BorderThickness="1" Padding="28,24">
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="*"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
      </Grid.RowDefinitions>

      <TextBlock Grid.Row="0"
                 Text="Verification Failed"
                 FontSize="22" FontWeight="Bold"
                 Foreground="#DC2626"
                 HorizontalAlignment="Center"
                 Margin="0,0,0,6"/>

      <TextBlock Grid.Row="1"
                 Text="Are you still at your seat?"
                 FontSize="15" FontWeight="SemiBold"
                 Foreground="#0F172A"
                 HorizontalAlignment="Center"
                 Margin="0,0,0,10"/>

      <TextBlock Grid.Row="2" x:Name="MessageText"
                 Text="No keyboard/mouse activity, and face check did not match your enrollment. If you are still here, click I'm Here."
                 FontSize="13"
                 TextAlignment="Center"
                 Foreground="#475569"
                 TextWrapping="Wrap"
                 LineHeight="19"
                 Margin="0,0,0,8"/>

      <TextBlock Grid.Row="3" x:Name="DetailText"
                 Text=""
                 FontSize="11"
                 TextAlignment="Center"
                 Foreground="#64748B"
                 TextWrapping="Wrap"
                 Margin="0,0,0,12"
                 MaxHeight="48"
                 TextTrimming="CharacterEllipsis"/>

      <TextBlock Grid.Row="4" x:Name="CountdownText"
                 Text="0:30"
                 FontSize="40" FontWeight="Bold"
                 Foreground="#EA580C"
                 HorizontalAlignment="Center"
                 VerticalAlignment="Center"
                 Margin="0,4,0,16"/>

      <Button Grid.Row="5"
              x:Name="ImHereButton"
              Height="48"
              Margin="0,0,0,10"
              Cursor="Hand"
              Click="ImHere_Click"
              BorderThickness="0"
              Background="#007A5A">
        <Button.Template>
          <ControlTemplate TargetType="Button">
            <Border x:Name="Bd"
                    Background="#007A5A"
                    CornerRadius="8"
                    Padding="16,12">
              <TextBlock Text="I'm Here"
                         FontSize="16"
                         FontWeight="Bold"
                         Foreground="White"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Bd" Property="Background" Value="#059669"/>
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="Bd" Property="Background" Value="#047857"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Button.Template>
      </Button>

      <TextBlock Grid.Row="6"
                 Text="Only this button dismisses the popup — mouse movement in other apps does not."
                 FontSize="11"
                 Foreground="#94A3B8"
                 TextAlignment="Center"
                 TextWrapping="Wrap"/>
    </Grid>
  </Border>
</Window>
