<Window x:Class="InteractPresence.VerificationResultWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Interact Presence"
        Width="400" Height="90"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="False"
        Background="#FFFFFFF8"
        Topmost="True"
        ShowInTaskbar="True"
        ShowActivated="True"
        WindowStartupLocation="Manual">
  <!-- HRM toast look without AllowsTransparency (that hid/broke the popup). -->
  <Border x:Name="RootBorder"
          BorderThickness="1"
          BorderBrush="#6EE7B7"
          Background="#F0FDF9">
    <Grid>
      <Border x:Name="AccentBar"
              Width="5"
              HorizontalAlignment="Left"
              Background="#007A5A"/>

      <Grid Margin="14,12,12,14">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <Border x:Name="IconWrap"
                Grid.Column="0"
                Width="34" Height="34"
                CornerRadius="10"
                Background="#ECFDF5"
                VerticalAlignment="Top"
                Margin="4,0,12,0">
          <TextBlock x:Name="IconText"
                     Text="✓"
                     FontSize="16"
                     FontWeight="Bold"
                     Foreground="#007A5A"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center"/>
        </Border>

        <StackPanel Grid.Column="1" VerticalAlignment="Center">
          <TextBlock x:Name="TitleText"
                     Text="SUCCESS"
                     FontSize="12"
                     FontWeight="Bold"
                     Foreground="#007A5A"/>
          <TextBlock x:Name="BodyText"
                     Text="Verification successful — you are present."
                     FontSize="13"
                     FontWeight="SemiBold"
                     Foreground="#1D1C1D"
                     TextWrapping="Wrap"
                     Margin="0,3,0,0"/>
        </StackPanel>

        <Border Grid.Column="2"
                Width="26" Height="26"
                CornerRadius="8"
                BorderBrush="#E8EDF3"
                BorderThickness="1"
                Background="White"
                VerticalAlignment="Top"
                Cursor="Hand"
                MouseLeftButtonUp="Close_Click">
          <TextBlock Text="×"
                     FontSize="16"
                     Foreground="#64748B"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center"/>
        </Border>
      </Grid>

      <Border VerticalAlignment="Bottom" Height="3" Background="#E2E8F0">
        <Border x:Name="ProgressBar"
                HorizontalAlignment="Left"
                Height="3"
                Width="400"
                Background="#007A5A"/>
      </Border>
    </Grid>
  </Border>
</Window>
