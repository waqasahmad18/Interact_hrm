# Copy this file to zkbio-sync.local.env (same folder) and fill values.
# zkbio-sync.local.env is gitignored — never commit it.

# ZKBio (DevTools → accTransaction → Headers + Payload)
ZKBIO_BASE=https://192.168.10.29:8098
ZKBIO_SESSION=

# POST + ?list often returns JSON; plain accTransaction.do may return HTML grid shell.
ZKBIO_HTTP_METHOD=post
ZKBIO_LIST_PATH=accTransaction.do?list

# If server errors on jqGrid extras, set: ZKBIO_JQGRID_EXTRAS=false

# browser-token: some builds require it (DevTools → Request Headers).
# ZKBIO_BROWSER_TOKEN=

# Copy remaining fields from Payload (form body) as key=value&key2=value2
# Do NOT duplicate startTime/endTime/page/rows here — the script sets those.
# Example (adjust to match your Payload tab):
# ZKBIO_EXTRA_FORM=!nativeeditor_status=load

# If grid uses posStart/count instead of page/rows:
# ZKBIO_PAGINATION=dhtmlx

# MySQL (same as your HRM app)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=interact_hrm

# Self-signed HTTPS on ZKBio
ZKBIO_VERIFY_SSL=false

# Debug: print JSON keys / snippet when 0 rows parsed (empty table but API has data)
# ZKBIO_DEBUG=1

# Auto-login (avoid manual SESSION refresh). DO NOT commit real creds.
# ZKBIO_USERNAME=
# ZKBIO_PASSWORD=
# If captcha is enabled, provide checkCode manually.
# ZKBIO_CHECKCODE=

# Rows per request (UI often 50). If JSON has no "total" pages, must match server page size.
# ZKBIO_PAGE_SIZE=50

# Incremental sync (when you do NOT pass --start/--end on the command line):
# Machine window never starts before ZKBIO_SYNC_SINCE. If unset: 1 March of current "season"
# (Mar–Dec → this year 1 Mar; Jan–Feb → last year 1 Mar). Then DB MAX(event_time) drives daily catch-up.
# ZKBIO_SYNC_SINCE=2026-03-01 00:00:00
# Re-fetch a few minutes of overlap so late rows are not missed; duplicates are skipped (INSERT IGNORE + unique index).
# ZKBIO_SYNC_OVERLAP_MINUTES=5
# One-off backfill before ZKBIO_SYNC_SINCE: use --start/--end AND set ZKBIO_ALLOW_BEFORE_SYNC_SINCE=1

# After first deploy, run scripts/zkbio-punch-log-dedupe.sql once: delete duplicate rows and add UNIQUE(log_id) + UNIQUE(pin, event_time).
